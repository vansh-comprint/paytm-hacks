# Copy to .env and fill in. .env is gitignored — never commit the real key.

SARVAM_API_KEY=sk_xxx_your_key_here
PORT=8000

# Sarvam models (verified current 2026-06-06; AGENTS.md's `sarvam-m` is deprecated)
# Sarvam = STT (Saaras) + TTS (Bulbul). The Sarvam LLM is only the router FALLBACK.
SARVAM_STT_MODEL=saaras:v2.5
SARVAM_LLM_MODEL=sarvam-30b
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya
REPLY_LANG=hi-IN

# Intent router LLM = Groq (fast, non-reasoning ~350ms; Sarvam's LLMs are slow reasoning models).
# Set ROUTER_PROVIDER=sarvam to force the fallback. Get a key at console.groq.com.
ROUTER_PROVIDER=groq
GROQ_API_KEY=gsk_xxx_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# WhatsApp: mock (default) | openwa (real send via local OpenWA gateway on :2785)
WHATSAPP_MODE=mock
OPENWA_URL=http://localhost:2785
OPENWA_KEY=dev-admin-key
OPENWA_SESSION=default

# Payment (mock Paytm-styled link)
MERCHANT_NAME=Sharma General Store
MERCHANT_VPA=sharmastore@paytm

# Demo: if set, ALL seed contacts + suppliers use this phone (every WhatsApp/reminder lands here).
# Leave blank to use the per-contact numbers in seed.json.
DEMO_PHONE=
